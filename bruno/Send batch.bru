meta {
  name: Send batch
  type: http
  seq: 3
}

post {
  url: {{URL}}/v1/send-batch
  body: json
  auth: bearer
}

auth:bearer {
  token: {{TOKEN}}
}

body:json {
  {
    "messages": [
      {
        "tokens": [],
        "notification": {
          "title": "Hello",
          "body": "World"
        }
      }
    ]
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
